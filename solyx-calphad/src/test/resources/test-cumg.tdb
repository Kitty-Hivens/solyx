$ Cu-Mg binary system - minimal test database for Solyx parser
$ Based on published Cu-Mg thermodynamic assessment
$ For testing purposes only

ELEMENT /-   ELECTRON_GAS  0.0000E+00  0.0000E+00  0.0000E+00 !
ELEMENT VA   VACUUM        0.0000E+00  0.0000E+00  0.0000E+00 !
ELEMENT CU   FCC_A1        6.3546E+01  5.0041E+03  3.3150E+01 !
ELEMENT MG   HCP_A3        2.4305E+01  4.9980E+03  3.2671E+01 !

$ Functions for pure elements
FUNCTION GHSERCU 298.15
 -7770.458+130.485235*T-24.112392*T*LN(T)
 -.00265684*T**2+1.29223E-07*T**3+52478*T**(-1); 1357.77 Y
 -13542.026+183.803828*T-31.38*T*LN(T)+3.64167E+29*T**(-9); 3200 N !

FUNCTION GHSERMG 298.15
 -8367.34+143.675547*T-26.1849782*T*LN(T)
 +4.858E-04*T**2-1.393669E-06*T**3+78950*T**(-1); 923 Y
 -14130.185+204.716215*T-34.3088*T*LN(T)+1.038192E+28*T**(-9); 3000 N !

FUNCTION GLIQCU 298.15
 +GHSERCU+12964.735-9.511904*T; 1357.77 Y
 -46.545+173.881484*T-31.38*T*LN(T); 3200 N !

FUNCTION GLIQMG 298.15
 +GHSERMG+8202.243-8.83693*T; 923 Y
 -5439.869+195.324057*T-34.3088*T*LN(T); 3000 N !

$ Liquid phase - single sublattice, no magnetism
PHASE LIQUID % 1 1.0 !
CONSTITUENT LIQUID :CU,MG : !

PARAMETER G(LIQUID,CU;0) 298.15 +GLIQCU; 3200 N !
PARAMETER G(LIQUID,MG;0) 298.15 +GLIQMG; 3000 N !
PARAMETER L(LIQUID,CU,MG;0) 298.15 -34000+4.0*T; 3000 N !
PARAMETER L(LIQUID,CU,MG;1) 298.15 -5000+3.0*T; 3000 N !

$ FCC phase - with magnetic TYPE_DEF (Cu is not magnetic but tests the syntax)
TYPE_DEF A GES A_P_D FCC_A1 MAGNETIC -3.0 2.80000E-01 !
PHASE FCC_A1 %A 2 1 1 !
CONSTITUENT FCC_A1 :CU,MG : VA : !

PARAMETER G(FCC_A1,CU:VA;0) 298.15 +GHSERCU; 3200 N !
PARAMETER G(FCC_A1,MG:VA;0) 298.15 +GHSERMG+2600-0.9*T; 3000 N !
PARAMETER L(FCC_A1,CU,MG:VA;0) 298.15 -12000+2.0*T; 3000 N !

$ HCP phase - two sublattices
PHASE HCP_A3 % 2 1 0.5 !
CONSTITUENT HCP_A3 :CU,MG : VA : !

PARAMETER G(HCP_A3,CU:VA;0) 298.15 +GHSERCU+600+0.2*T; 3200 N !
PARAMETER G(HCP_A3,MG:VA;0) 298.15 +GHSERMG; 3000 N !

$ Stoichiometric compound CuMg2 - no mixing
PHASE CUMG2 % 2 1 2 !
CONSTITUENT CUMG2 :CU : MG : !

PARAMETER G(CUMG2,CU:MG;0) 298.15
 +GHSERCU+2*GHSERMG-18000+5.0*T; 3000 N !
